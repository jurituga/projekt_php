# Copy to .env before running the desktop app:
#   cp .env.nativephp.example .env
#
# NativePHP requires PHP 8.3+ and Node.js 22+.

APP_NAME=Vacanto
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# SQLite — bundled with the desktop app (no MySQL server needed)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# File-based sessions work offline
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

# NativePHP app metadata
NATIVEPHP_APP_ID=com.vacanto.desktop
NATIVEPHP_APP_VERSION=1.0.0
NATIVEPHP_APP_DESCRIPTION=Vacanto — jobs and freelance services platform
NATIVEPHP_UPDATER_ENABLED=false

# Stripe (optional — leave empty for offline demo)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=usd
